{
  "info": {
    "name": "MegaNova Application API",
    "description": "API collection for MegaNova AI Load Balancer. The load balancer ignores the `model` field in request bodies and selects the model via round-robin.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "meganova-api-collection"
  },
  "item": [
    {
      "name": "Chat Completions",
      "item": [
        {
          "name": "Create Chat Completion",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer kl5Ik7d8HFVgEpAiTmqRh6hkxjvYFFZ3",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a helpful assistant.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello, how are you?\"\n    }\n  ],\n  \"max_tokens\": 1024,\n  \"temperature\": 0.7,\n  \"top_p\": 0.9,\n  \"stream\": false\n}"
            },
            "url": {
              "raw": "https://llm-api-lnvj.onrender.com/v1/chat/completions",
              "protocol": "https",
              "host": [
                "llm-api-lnvj",
                "onrender",
                "com"
              ],
              "path": [
                "v1",
                "chat",
                "completions"
              ]
            },
            "description": "Create a chat completion."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200, 400 or 503', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 503]);",
                  "});"
                ]
              }
            }
          ]
        },
